{
  "framework": null,
  "outputDirectory": "frontend/dist",
  "buildCommand": "NODE_ENV=development npm install --prefix frontend && npm run frontend:build && npm install",
  "installCommand": "npm install && npm install --prefix frontend",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/((?!api).*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}